<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0D1B2A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BOTÓN VOLVER -->
    <Button
        android:id="@+id/btnBack"
        android:text="⬅ Volver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- INFO JUGADOR -->
    <TextView
        android:id="@+id/txtMoney"
        android:text="Dinero"
        android:textSize="20sp"
        android:textColor="#00E676"
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtTurn"
        android:text="Turno"
        android:textColor="#FFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- RESULTADO -->
    <TextView
        android:id="@+id/txtResult"
        android:text="Resultado"
        android:textColor="#FFD60A"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- BOTONES ESTILO MOCKUP -->

    <Button
        android:id="@+id/btnAhorrar"
        android:text="💰 AHORRAR (+200)"
        android:backgroundTint="#2ECC71"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnInvertir"
        android:text="📈 INVERTIR (riesgo)"
        android:backgroundTint="#3498DB"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnGastar"
        android:text="🛒 GASTAR (-150)"
        android:backgroundTint="#E74C3C"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnReset"
        android:text="🔄 Reiniciar"
        android:backgroundTint="#FFD60A"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>